{
	"extends": "../tsconfig.json",
	"compilerOptions": {
		/* Modules */
		"moduleResolution": "node",

		/* Type Checking */
		"noImplicitAny": false,

		"paths": {
			"@utils/*": [
				"./src/utils/*",
			],
		},
	},
	"include": ["src"],
	"exclude": ["node_modules", ".vscode-test-web", "src/**/*.test.ts"],
}
